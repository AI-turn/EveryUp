# =============================================
# EveryUp Log Agent 설정
# 이 파일을 .env로 복사하여 값을 채우세요:
#   cp .env.example .env
# =============================================

# EveryUp 서버 URL (필수)
MT_ENDPOINT=http://your-everyup-server:3001

# 서비스 API Key (필수) — EveryUp 대시보드 > 서비스 > Integration 탭에서 복사
MT_API_KEY=mt_your_api_key_here

# 수집할 로그 파일 경로 (glob 지원)
MT_FILE=/var/log/app/*.log

# 로그 레벨 (debug / info / warn / error)
MT_LOG_LEVEL=info

# 호스트의 로그 디렉토리 경로 (컨테이너 내부 /var/log/app 로 마운트됨)
LOG_PATH=/path/to/your/app/logs

# =============================================
# 테스트 콘솔 UI (선택)
# =============================================

# 테스트 콘솔 활성화 여부
MT_TEST=false

# 테스트 콘솔 포트
MT_TEST_PORT=8080
